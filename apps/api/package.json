{
  "name": "@pgos/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run --passWithNoTests",
    "clean": "rimraf dist",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@pgos/core": "workspace:*",
    "@pgos/context-engine": "workspace:*",
    "@pgos/model-adapters": "workspace:*",
    "@pgos/recovery-engine": "workspace:*",
    "@pgos/validation-engine": "workspace:*",
    "@pgos/hallucination-detector": "workspace:*",
    "@pgos/architecture-guard": "workspace:*",
    "@pgos/observability": "workspace:*",
    "@pgos/semantic-git": "workspace:*",
    "@pgos/memory-engine": "workspace:*",
    "@pgos/agent-runtime": "workspace:*",
    "@pgos/doc-engine": "workspace:*",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.1",
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^12.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/websocket": "^11.0.0",
    "drizzle-orm": "^0.33.0",
    "postgres": "^3.4.0",
    "dotenv": "^16.4.0",
    "zod": "^3.23.0",
    "socket.io": "^4.7.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "tsx": "^4.16.0",
    "vitest": "^2.0.0",
    "rimraf": "^5.0.0",
    "drizzle-kit": "^0.24.0",
    "@types/node": "^22.0.0"
  }
}
