    "@pgos/hallucination-detector": "workspace:*",
    "@pgos/architecture-guard": "workspace:*",
    "@pgos/model-adapters": "workspace:*",
    "@pgos/doc-engine": "workspace:*",
    "commander": "^12.1.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.0",
    "cli-table3": "^0.6.5",
    "inquirer": "^10.0.0",
    "boxen": "^8.0.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "tsx": "^4.16.0",
    "rimraf": "^5.0.0",
