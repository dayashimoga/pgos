# ============================================================
# PGOS — Test Runner Dockerfile
# Self-contained image that:
#   1. Installs pnpm and all workspace dependencies
#   2. Builds the TypeScript source
#   3. Runs the full vitest test suite
# No local Node.js, pnpm, or npm required on the host.
# ============================================================

FROM node:20-slim AS base

# Enable pnpm via corepack (ships with Node 20, no network needed)
RUN corepack enable && corepack prepare pnpm@9.1.0 --activate

WORKDIR /app

# ── Stage: dependency install ────────────────────────────────
FROM base AS deps

# Copy workspace manifests first for layer caching
COPY pnpm-workspace.yaml ./
COPY pnpm-lock.yaml ./
COPY package.json ./
COPY tsconfig.base.json ./
COPY turbo.json ./

# Copy all package.json files (for dependency resolution)
COPY packages/core/package.json            ./packages/core/
COPY packages/context-engine/package.json  ./packages/context-engine/
COPY packages/token-optimizer/package.json ./packages/token-optimizer/
COPY packages/validation-engine/package.json ./packages/validation-engine/
COPY packages/agent-runtime/package.json   ./packages/agent-runtime/
COPY packages/architecture-guard/package.json ./packages/architecture-guard/
COPY packages/doc-engine/package.json      ./packages/doc-engine/
COPY packages/hallucination-detector/package.json ./packages/hallucination-detector/
COPY packages/memory-engine/package.json   ./packages/memory-engine/
COPY packages/model-adapters/package.json  ./packages/model-adapters/
COPY packages/observability/package.json   ./packages/observability/
COPY packages/policy-engine/package.json   ./packages/policy-engine/
COPY packages/recovery-engine/package.json ./packages/recovery-engine/
COPY packages/semantic-git/package.json    ./packages/semantic-git/
COPY packages/test-engine/package.json     ./packages/test-engine/
COPY apps/api/package.json                 ./apps/api/
COPY apps/cli/package.json                 ./apps/cli/
COPY apps/dashboard/package.json           ./apps/dashboard/

# Install ALL workspace dependencies (frozen lockfile for reproducibility)
RUN pnpm install --no-frozen-lockfile

# ── Stage: source + test ─────────────────────────────────────
FROM deps AS test

# Copy the full source tree
COPY packages/ ./packages/
COPY apps/     ./apps/

# Build all packages so workspace dependencies resolve
RUN pnpm build

# Default: run context-engine tests
# Override with: docker run ... pgos-test-runner sh -c "pnpm --filter @pgos/core test"
CMD ["pnpm", "--filter", "@pgos/context-engine", "--filter", "@pgos/core", "test", "--", "--reporter=verbose"]
