    "clean": "rimraf dist"
  },
  "dependencies": {
    "@pgos/core": "workspace:*",
    "@pgos/token-optimizer": "workspace:*",
    "glob": "^10.3.0",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "rimraf": "^5.0.0"
  }
}
