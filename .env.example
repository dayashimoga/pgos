# ==========================================
# PGOS — Project Guardian OS Configuration
# ==========================================

# Server
NODE_ENV=development
API_PORT=3001
API_HOST=0.0.0.0
API_LOG_LEVEL=info

# Dashboard
DASHBOARD_PORT=3000

# Database
DATABASE_URL=postgresql://pgos:pgos_dev@localhost:5432/pgos
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Redis
REDIS_URL=redis://localhost:6379

# ChromaDB (Vector Database)
CHROMA_URL=http://localhost:8000

# Authentication
JWT_SECRET=change-me-in-production-use-a-strong-secret
JWT_EXPIRES_IN=7d
API_KEY_SALT=change-me-in-production

# AI Model Providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

# Ollama (Local)
OLLAMA_BASE_URL=http://localhost:11434

# vLLM
VLLM_BASE_URL=http://localhost:8000

# LM Studio
LMSTUDIO_BASE_URL=http://localhost:1234

# Embeddings
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Storage
SNAPSHOT_STORAGE_PATH=.guardian/snapshots
ARTIFACT_STORAGE_PATH=.guardian/artifacts

# Encryption
ENCRYPTION_KEY=change-me-in-production-32-chars!!

# Observability
ENABLE_TELEMETRY=true
METRICS_RETENTION_DAYS=90

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
